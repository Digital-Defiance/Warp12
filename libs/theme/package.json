{
  "name": "warp12-theme",
  "version": "0.4.26",
  "description": "Federation-styled domino theme presets for Warp — Interstellar Dominoes visual styling for DoubleEighteen across all Warp factors",
  "homepage": "https://warp.iwdf.org",
  "license": "MIT",
  "author": "Digital Defiance",
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@warp12/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "warp",
    "warp12",
    "warp-dominoes",
    "interstellar-dominoes",
    "double-eighteen",
    "dominoes",
    "theme",
    "federation",
    "visual-theme"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Digital-Defiance/Warp12.git",
    "directory": "libs/theme"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prepublishOnly": "cd ../.. && yarn build:theme"
  },
  "peerDependencies": {
    "double-eighteen": ">=0.4.0"
  },
  "devDependencies": {
    "double-eighteen": "workspace:*"
  }
}
