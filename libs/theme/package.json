{
  "name": "warp12-theme",
  "version": "0.4.23",
  "description": "Warp 12 federation domino theme presets for DoubleTwelve",
  "license": "MIT",
  "author": "Digital Defiance",
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@warp12/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "warp12",
    "doubletwelve",
    "dominoes",
    "theme"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Digital-Defiance/Warp12.git",
    "directory": "libs/theme"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prepublishOnly": "cd ../.. && yarn build:theme"
  },
  "peerDependencies": {
    "doubletwelve": ">=0.3.2"
  },
  "devDependencies": {
    "doubletwelve": "workspace:*"
  }
}
