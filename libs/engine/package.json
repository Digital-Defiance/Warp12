{
  "name": "warp12-engine",
  "version": "0.4.27",
  "description": "Warp game engine — rules, state machine, and AI for multi-trail Interstellar Dominoes across Warp factors 9/12/15/18 (double-N sets). Warp 12 is the only IWGF-rated variant.",
  "homepage": "https://warp.iwgf.org",
  "license": "MIT",
  "author": "Digital Defiance",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@warp12/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "@warp12/source": "./src/node.ts",
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "warp",
    "warp12",
    "warp-dominoes",
    "interstellar-dominoes",
    "mexican-train",
    "dominoes",
    "game-engine",
    "board-game",
    "double-nine",
    "double-twelve",
    "double-fifteen",
    "double-eighteen"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Digital-Defiance/Warp12.git",
    "directory": "libs/engine"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prepublishOnly": "cd ../.. && yarn build:engine && yarn test:engine"
  },
  "peerDependencies": {
    "double-eighteen": ">=0.4.0"
  },
  "devDependencies": {
    "double-eighteen": "workspace:*"
  }
}
