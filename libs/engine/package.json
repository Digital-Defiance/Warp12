{
  "name": "warp12-engine",
  "version": "0.4.23",
  "description": "Warp 12 game engine — rules, state machine, Warp AI, and advisor explanations",
  "license": "MIT",
  "author": "Digital Defiance",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@warp12/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "@warp12/source": "./src/node.ts",
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "warp12",
    "mexican-train",
    "dominoes",
    "game-engine",
    "board-game"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Digital-Defiance/Warp12.git",
    "directory": "libs/engine"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prepublishOnly": "cd ../.. && yarn build:engine && yarn test:engine"
  },
  "peerDependencies": {
    "doubletwelve": ">=0.3.2"
  },
  "devDependencies": {
    "doubletwelve": "workspace:*"
  }
}
