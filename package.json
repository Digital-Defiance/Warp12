{
  "name": "@warp12/source",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/devkit": "23.0.1",
    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/playwright": "23.0.1",
    "@nx/react": "23.0.1",
    "@nx/vite": "23.0.1",
    "@nx/vitest": "23.0.1",
    "@nx/web": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@playwright/test": "^1.37.0",
    "@swc/cli": "~0.8.0",
    "@swc/core": "^1.15.43",
    "@swc/helpers": "~0.5.18",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "~4.1.0",
    "@vitest/ui": "~4.1.0",
    "ajv": "^8.0.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-playwright": "^1.6.2",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "jiti": "2.4.2",
    "jsdom": "^27.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "23.0.1",
    "prettier": "~3.6.2",
    "sass": "^1.97.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "~4.5.0",
    "vitest": "~4.1.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*",
    "vendor/*"
  ],
  "packageManager": "yarn@4.17.0",
  "scripts": {
    "nx:unlock": "nx daemon --stop 2>/dev/null || true && rm -rf .nx/workspace-data .nx/cache && echo 'Nx daemon stopped and cache cleared.'",
    "build:doubletwelve": "cd vendor/DoubleTwelve && node ./node_modules/vite/bin/vite.js build --config vite.lib.config.ts && rm -f dist/package.json",
    "build:engine": "vite build --config libs/Warp12-lib/vite.config.mts",
    "build:bridge": "vite build --config apps/Warp12/vite.config.mts",
    "build:all": "yarn build:doubletwelve && yarn build:engine && yarn build:bridge",
    "test:engine": "vitest run --config libs/Warp12-lib/vite.config.mts",
    "test:bridge": "vitest run --config apps/Warp12/vite.config.mts",
    "test:e2e": "yarn build:bridge && playwright test --config apps/Warp12-e2e/playwright.config.mts",
    "test:all": "yarn test:engine && yarn test:bridge && yarn test:e2e",
    "serve:bridge": "vite --config apps/Warp12/vite.config.mts",
    "preview:bridge": "vite preview --config apps/Warp12/vite.config.mts",
    "deploy:firestore": "firebase deploy --only firestore:rules --project warp-12",
    "deploy:hosting": "yarn build:all && firebase deploy --only hosting --project warp-12",
    "deploy:firebase": "yarn build:all && firebase deploy --only firestore:rules,hosting --project warp-12"
  },
  "dependencies": {
    "@swc-node/register": "^1.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "6.30.3"
  }
}
