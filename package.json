{
  "name": "@warp12/source",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/devkit": "23.0.1",
    "@nx/eslint": "23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/js": "23.0.1",
    "@nx/playwright": "23.0.1",
    "@nx/react": "23.0.1",
    "@nx/vite": "23.0.1",
    "@nx/vitest": "23.0.1",
    "@nx/web": "23.0.1",
    "@nx/workspace": "23.0.1",
    "@playwright/test": "^1.37.0",
    "@swc/cli": "~0.8.0",
    "@swc/core": "^1.15.43",
    "@swc/helpers": "~0.5.18",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "~4.1.0",
    "@vitest/ui": "~4.1.0",
    "ajv": "^8.0.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-playwright": "^1.6.2",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "jiti": "2.4.2",
    "jsdom": "^27.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "23.0.1",
    "prettier": "~3.6.2",
    "sass": "^1.97.2",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "~4.5.0",
    "vitest": "~4.1.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*",
    "vendor/*"
  ],
  "packageManager": "yarn@4.17.0",
  "scripts": {
    "nx:unlock": "nx daemon --stop 2>/dev/null || true && rm -rf .nx/workspace-data .nx/cache && echo 'Nx daemon stopped and cache cleared.'",
    "build:doubletwelve": "cd vendor/DoubleTwelve && node ./node_modules/vite/bin/vite.js build --config vite.lib.config.ts && rm -f dist/package.json",
    "build:engine": "vite build --config libs/engine/vite.config.mts",
    "build:react": "vite build --config libs/react/vite.config.mts",
    "build:theme": "vite build --config libs/theme/vite.config.mts",
    "build:bridge": "vite build --config apps/Warp12/vite.config.mts",
    "build:leaderboard": "cd Warp12-leaderboard && yarn build",
    "build:all": "yarn build:doubletwelve && yarn build:engine && yarn build:react && yarn build:theme && yarn build:bridge",
    "build:all:hosting": "yarn build:all && yarn build:leaderboard",
    "build:libs": "yarn build:doubletwelve && yarn build:engine && yarn build:react && yarn build:theme",
    "test:engine": "vitest run --config libs/engine/vite.config.mts",
    "calibrate:ai-elo": "AI_CALIBRATION_REPORT=1 vitest run --config libs/engine/vite.config.mts src/lib/ai/ai-elo-calibration.spec.ts -t \"prints a calibration\"",
    "optimize:ai-weights": "AI_WEIGHT_OPTIMIZE=1 AI_OPTIMIZER_PARALLEL=1 vitest run --config libs/engine/vite.config.mts src/lib/ai/ai-weight-optimizer.spec.ts -t \"prints optimizer\"",
    "test:react": "vitest run --config libs/react/vite.config.mts",
    "test:bridge": "vitest run --config apps/Warp12/vite.config.mts",
    "test:libs": "yarn test:engine && yarn test:react",
    "test:e2e": "yarn build:bridge && playwright test --config apps/Warp12-e2e/playwright.config.mts",
    "test:all": "yarn test:engine && yarn test:react && yarn test:bridge && yarn test:e2e",
    "pack:doubletwelve": "yarn build:doubletwelve && (cd vendor/DoubleTwelve && npm pack --dry-run)",
    "pack:engine": "yarn build:engine && (cd libs/engine && npm pack --dry-run)",
    "pack:react": "yarn build:react && (cd libs/react && npm pack --dry-run)",
    "pack:theme": "yarn build:theme && (cd libs/theme && npm pack --dry-run)",
    "pack:libs": "yarn build:libs && yarn pack:engine && yarn pack:react && yarn pack:theme",
    "prepublish:check": "yarn build:libs && yarn test:libs",
    "publish:doubletwelve": "bash scripts/npm-publish-otp.sh vendor/DoubleTwelve",
    "publish:engine": "bash scripts/npm-publish-otp.sh libs/engine",
    "publish:react": "bash scripts/npm-publish-otp.sh libs/react",
    "publish:theme": "bash scripts/npm-publish-otp.sh libs/theme",
    "publish:libs": "bash scripts/publish-warp12-libs.sh",
    "publish:all": "bash scripts/npm-publish-otp.sh vendor/DoubleTwelve && bash scripts/publish-warp12-libs.sh",
    "serve:bridge": "vite --config apps/Warp12/vite.config.mts",
    "preview:bridge": "vite preview --config apps/Warp12/vite.config.mts",
    "tauri:dev": "cd apps/Warp12 && ../../node_modules/.bin/tauri dev",
    "tauri:build": "cd apps/Warp12 && ../../node_modules/.bin/tauri build",
    "tauri:icon": "cd apps/Warp12 && ../../node_modules/.bin/tauri icon public/W12-1-1.png",
    "sync:ios-icons": "/usr/bin/env bash scripts/sync-ios-icons.sh",
    "sync:android-icons": "/usr/bin/env bash scripts/sync-android-icons.sh",
    "tauri:ios:dev": "cd apps/Warp12 && ../../node_modules/.bin/tauri ios dev",
    "tauri:ios:build": "cd apps/Warp12 && ../../node_modules/.bin/tauri ios build",
    "tauri:ios:build:appstore": "/usr/bin/env bash scripts/build-ios-appstore.sh",
    "tauri:android:dev": "cd apps/Warp12 && ../../node_modules/.bin/tauri android dev",
    "tauri:android:build": "cd apps/Warp12 && ../../node_modules/.bin/tauri android build",
    "build:mac": "/usr/bin/env bash scripts/build-macos.sh",
    "build:mac-appstore": "/usr/bin/env bash scripts/build-macos-appstore.sh",
    "build:ios-appstore": "/usr/bin/env bash scripts/build-ios-appstore.sh",
    "build:android": "/usr/bin/env bash scripts/build-android.sh",
    "build:android:apk": "/usr/bin/env bash scripts/build-android.sh --apk",
    "deploy:firestore": "firebase deploy --only firestore --project warp-12",
    "deploy:hosting:bridge": "yarn build:all && firebase deploy --only hosting:bridge --project warp-12",
    "deploy:hosting:leaderboard": "yarn build:leaderboard && firebase deploy --only hosting:leaderboard --project warp-12",
    "deploy:hosting": "yarn build:all:hosting && firebase deploy --only hosting --project warp-12",
    "deploy:firebase": "yarn build:all:hosting && firebase deploy --only firestore,hosting --project warp-12"
  },
  "dependencies": {
    "@swc-node/register": "^1.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "6.30.3"
  }
}
