# Warp12 developer / organization / signing configuration
# ---------------------------------------------------------------------------
# Copy to `.env` (gitignored) and fill in values for your org or fork.
# Process environment always wins over this file.
#
#   cp .env.example .env
#
# Also see:
#   apps/Warp12/.env.example   — Firebase web + Google OAuth (Vite)
#   functions/.env.example     — Cloud Functions secrets
# ---------------------------------------------------------------------------

# --- Apple / Tauri identity (required for macOS / iOS release builds) --------
APPLE_TEAM_ID=
# Bundle / application id (also used for Android applicationId)
APPLE_BUNDLE_ID=
# Publisher / certificate CN organization name
APPLE_PUBLISHER_NAME=
# Optional: full signing identity strings
# APPLE_SIGNING_IDENTITY=Developer ID Application: Your Org (TEAMID)
# APPLE_IOS_SIGN_IDENTITY=Apple Distribution: Your Org (TEAMID)
# DEFAULT_DEVELOPER_ID_TEAM=   # preferred Developer ID team when multiple exist

# App Store Connect API key (preferred notarization / upload)
# APPLE_API_KEY=
# APPLE_API_ISSUER=
# APPLE_API_KEY_PATH=          # or APPLE_API_KEY_DIR=$HOME/private_keys
# APPLE_API_KEY_DIR=$HOME/private_keys

# Apple ID + app-specific password (alternate notarization)
# APPLE_ID=
# APPLE_PASSWORD=

# Signing artifact paths (defaults relative to apps/Warp12/src-tauri/)
# APPLE_PROVISIONING_PROFILE=apps/Warp12/src-tauri/Warp_12.provisionprofile
# APPLE_IOS_PROVISIONING_PROFILE=apps/Warp12/src-tauri/Warp_12_iOS.mobileprovision
# APPLE_IOS_CERTIFICATE=apps/Warp12/src-tauri/Warp_12_iOS.p12
# APPLE_IOS_CERTIFICATE_PASSWORD=
# ANDROID_KEYSTORE=apps/Warp12/src-tauri/Warp_12_upload.jks
# ANDROID_KEY_ALIAS=upload
# ANDROID_KEYSTORE_PASSWORD=

# --- Firebase / hosting -----------------------------------------------------
FIREBASE_PROJECT=
# Comma-separated Auth authorized domains (ensure-auth-authorized-domains.sh)
FIREBASE_AUTH_AUTHORIZED_DOMAINS=
FUNCTIONS_REGION=us-central1
# Emulator-only project id for yarn test:e2e:firebase
FIREBASE_E2E_PROJECT=demo-warp12

# Public origins used by invite links, certificates, and share URLs
PUBLIC_BRIDGE_ORIGIN=
PUBLIC_LEADERBOARD_ORIGIN=
PUBLIC_OPS_ORIGIN=
PUBLIC_HOMEBREW_URL=

# --- GitHub / Homebrew ------------------------------------------------------
GITHUB_REPO=
HOMEBREW_TAP_DIR=
# HOMEBREW_CASK_PATH=          # default $HOMEBREW_TAP_DIR/Casks/warp12.rb

# --- Analysis / training worker tuning (optional) ---------------------------
# Leave unset to auto-detect: max(1, CPU cores - 2)
# MODULE_WORKERS=
# COMPREHENSIVE_WORKERS=
# OMEGA_WORKERS=
# MODULE_GAMES=500
# COMPREHENSIVE_GAMES=500
# MODULE_OBJECTIVE=points
# COMPREHENSIVE_OBJECTIVE=points
# MODULE_SEED=9001
# COMPREHENSIVE_SEED=9001

# --- Misc -------------------------------------------------------------------
# NONINTERACTIVE=1             # fail instead of prompting for secrets
# WARP12_PUSH_HOMEBREW_TAP=0
# WARP12_CREATE_GIT_TAG=0
