rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(data) {
      return isSignedIn()
        && data.captainIds != null
        && request.auth.uid in data.captainIds;
    }

    function isSpectator(data) {
      return isSignedIn()
        && data.spectatorIds != null
        && request.auth.uid in data.spectatorIds;
    }

    function isHost(data) {
      return isSignedIn() && request.auth.uid == data.hostId;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function profileIsPublic(data) {
      return data.visibility == 'public';
    }

    function logIsPublic(data) {
      return data.visibility == 'public';
    }

    function logIsReadable(data) {
      return logIsPublic(data)
        || (isSignedIn() && request.auth.uid == data.authorId);
    }

    function lobbyMissionSettingsUnchanged() {
      return request.resource.data.hostId == resource.data.hostId
        && request.resource.data.maxPlayers == resource.data.maxPlayers
        && request.resource.data.objective == resource.data.objective
        && request.resource.data.campaignRounds == resource.data.campaignRounds
        && request.resource.data.modules == resource.data.modules
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function lobbyRosterGrewByOne() {
      return request.resource.data.captainIds.size()
          == resource.data.captainIds.size() + 1
        && request.resource.data.captains.size()
          == resource.data.captains.size() + 1;
    }

    function lobbyRosterShrankByOne() {
      return request.resource.data.captainIds.size()
          == resource.data.captainIds.size() - 1
        && request.resource.data.captains.size()
          == resource.data.captains.size() - 1;
    }

    function isAiCaptainId(playerId) {
      return playerId.matches('^ai:.+');
    }

    function lobbyAiCaptainAdded() {
      return request.resource.data.captainIds.size()
          == resource.data.captainIds.size() + 1
        && request.resource.data.captains.size()
          == resource.data.captains.size() + 1
        && request.resource.data.captains[request.resource.data.captains.size() - 1].isAi == true;
    }

    function tokenRoles() {
      return request.auth.token.get('roles', []);
    }

    function isAdmin() {
      return isSignedIn()
        && tokenRoles() is list
        && 'admin' in tokenRoles();
    }

    function isMatchOfficial() {
      return isSignedIn()
        && tokenRoles() is list
        && ('match_official' in tokenRoles() || 'admin' in tokenRoles());
    }

    function isVerifiedUser() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Ban docs are Admin SDK only. Expiry is Timestamp or null.
    function isBanned() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/bans/$(request.auth.uid))
        && get(/databases/$(database)/documents/bans/$(request.auth.uid)).data.active == true
        && (
          get(/databases/$(database)/documents/bans/$(request.auth.uid)).data.expiresAt == null
          || get(/databases/$(database)/documents/bans/$(request.auth.uid)).data.expiresAt
               > request.time
        );
    }

    function notBanned() {
      return !isBanned();
    }

    // Global mute docs are Admin SDK only. Expiry is Timestamp or null.
    // mode == 'shadow' allows creates (hidden after write); omit/hard blocks.
    function isGloballyMuted() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/mutes/$(request.auth.uid))
        && get(/databases/$(database)/documents/mutes/$(request.auth.uid)).data.active == true
        && get(/databases/$(database)/documents/mutes/$(request.auth.uid)).data.get('mode', 'hard') != 'shadow'
        && (
          get(/databases/$(database)/documents/mutes/$(request.auth.uid)).data.expiresAt == null
          || get(/databases/$(database)/documents/mutes/$(request.auth.uid)).data.expiresAt
               > request.time
        );
    }

    function notGloballyMuted() {
      return !isGloballyMuted();
    }

    function sectorNotTerminated(data) {
      return data.get('opsTerminated', false) != true;
    }

    function ratedStatsFieldsUnchanged() {
      return request.resource.data.get('humanRating', null) == resource.data.get('humanRating', null)
        && request.resource.data.get('humanRatedGameIds', null) == resource.data.get('humanRatedGameIds', null)
        && request.resource.data.get('groupRating', null) == resource.data.get('groupRating', null)
        && request.resource.data.get('groupRatedIds', null) == resource.data.get('groupRatedIds', null)
        && request.resource.data.get('localAi', null) == resource.data.get('localAi', null)
        && request.resource.data.get('startingRating', null) == resource.data.get('startingRating', null)
        && request.resource.data.get('matchHistory', null) == resource.data.get('matchHistory', null)
        && request.resource.data.get('matchesCompleted', null) == resource.data.get('matchesCompleted', null)
        && request.resource.data.get('matchesWon', null) == resource.data.get('matchesWon', null)
        && request.resource.data.get('roundsPlayed', null) == resource.data.get('roundsPlayed', null)
        && request.resource.data.get('roundsWon', null) == resource.data.get('roundsWon', null)
        && request.resource.data.get('totalPoints', null) == resource.data.get('totalPoints', null)
        && request.resource.data.get('lastPlayedAt', null) == resource.data.get('lastPlayedAt', null);
    }

    function clientProfileFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['displayName', 'captainGender', 'updatedAt']);
    }

    function clientStatsCreate() {
      return request.resource.data.uid == uid
        && !request.resource.data.keys().hasAny([
          'humanRating',
          'humanRatedGameIds',
          'groupRating',
          'groupRatedIds',
          'localAi',
          'matchHistory',
          'startingRating',
          'lastPlayedAt'
        ])
        && request.resource.data.get('matchesCompleted', 0) == 0
        && request.resource.data.get('matchesWon', 0) == 0
        && request.resource.data.get('roundsPlayed', 0) == 0
        && request.resource.data.get('roundsWon', 0) == 0
        && request.resource.data.get('totalPoints', 0) == 0;
    }

    function safeStatsCreate() {
      return clientStatsCreate();
    }

    match /bans/{uid} {
      allow read, write: if false;
    }

    match /opsAudit/{id} {
      allow read, write: if false;
    }

    // Moderation queue/config/rate state is reachable only through validated
    // Cloud Functions. Reports may contain DM/squad evidence.
    match /moderationReports/{reportId} {
      allow read, write: if false;
    }

    match /moderationConfig/{configId} {
      allow read, write: if false;
    }

    match /moderationReportRate/{uid} {
      allow read, write: if false;
    }

    // TEI match ledger — Admin SDK only (ops callables). Prerequisite for cascade.
    match /ratingEvents/{eventId} {
      allow read, write: if false;
    }

    match /adminNotes/{uid} {
      allow read, write: if false;
    }

    match /mutes/{uid} {
      allow read, write: if false;
    }

    // Related-account / fingerprint signals — Admin SDK only.
    match /captainSignals/{uid} {
      allow read, write: if false;
    }
    match /ipSightings/{ipKey} {
      allow read, write: if false;
    }
    match /installSightings/{installId} {
      allow read, write: if false;
    }

    match /ratedMatches/{matchCode} {
      allow read: if isSignedIn();
      allow create, update, delete: if false;
    }

    // Module Zeta: squad-vs-squad archive written by reportOnlineMatch only.
    match /squadMatches/{gameId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.memberUids;
      allow create, update, delete: if false;
    }

    match /charters/{charterId} {
      allow read: if isSignedIn()
        && (
          resource.data.isGlobalOfficial == true
          || request.auth.uid in resource.data.memberUids
        );
      allow create, update, delete: if false;
    }

    match /charterMembers/{memberId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /charterJoinRequests/{requestId} {
      allow read, write: if false;
    }

    match /charterSeasonArchives/{archiveId} {
      allow read, write: if false;
    }

    match /games/{gameId} {
      // Any authenticated captain (or lobby guest who knows the code) can read.
      allow read: if isSignedIn();

      // Host opens a new sector lobby.
      allow create: if isSignedIn()
        && notBanned()
        && request.resource.data.phase == 'lobby'
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.captainIds.size() == 1
        && request.resource.data.captainIds[0] == request.auth.uid
        && request.resource.data.captains.size() == 1
        && request.resource.data.captains[0].id == request.auth.uid;

      allow update: if isSignedIn()
        && sectorNotTerminated(resource.data)
        && (
        // Banned captains may still leave a lobby so they are not stuck aboard.
        (resource.data.phase == 'lobby'
          && isMember(resource.data)
          && request.auth.uid in resource.data.captainIds
          && !(request.auth.uid in request.resource.data.captainIds)
          && lobbyRosterShrankByOne()
          && lobbyMissionSettingsUnchanged())
        ||
        (notBanned() && (
          // Host edits lobby settings or launches / resets the sector.
          (isHost(resource.data) && resource.data.phase == 'lobby')
          ||
          // Host toggles spectator gallery mid-mission (or in lobby).
          (isHost(resource.data)
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['allowSpectate', 'spectatorIds', 'updatedAt']))
          ||
          // Host pauses / resumes an active sector (temporary spectator mode).
          (isHost(resource.data)
            && resource.data.phase == 'active'
            && request.resource.data.phase == 'active'
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['paused', 'pausedAt', 'pausedBy', 'pauseReason', 'updatedAt']))
          ||
          // Host resets an active/completed sector back to lobby.
          (isHost(resource.data)
            && resource.data.phase in ['active', 'complete', 'round-end']
            && request.resource.data.phase == 'lobby')
          ||
          // Captain submits a move (engine validates inside the transaction).
          (isMember(resource.data)
            && resource.data.phase == 'active'
            && resource.data.paused != true
            && request.resource.data.phase in ['active', 'complete', 'round-end'])
          ||
          // New captain joins a lobby.
          (resource.data.phase == 'lobby'
            && isMember(request.resource.data)
            && !(request.auth.uid in resource.data.captainIds)
            && lobbyRosterGrewByOne()
            && lobbyMissionSettingsUnchanged())
          ||
          // Host removes a captain from the lobby.
          (resource.data.phase == 'lobby'
            && isHost(resource.data)
            && lobbyRosterShrankByOne()
            && lobbyMissionSettingsUnchanged())
          ||
          // Host adds an AI officer to the lobby.
          (resource.data.phase == 'lobby'
            && isHost(resource.data)
            && lobbyAiCaptainAdded()
            && lobbyMissionSettingsUnchanged())
        ))
      );

      allow delete: if isHost(resource.data)
        && notBanned()
        && sectorNotTerminated(resource.data)
        && resource.data.phase in ['lobby', 'active', 'complete', 'round-end'];

      match /mutes/{mutedUid} {
        allow read, write: if false;
      }

      match /presence/{playerId} {
        function parentGame() {
          return get(/databases/$(database)/documents/games/$(gameId)).data;
        }

        allow read: if isSignedIn() && (
          isMember(parentGame())
          || isSpectator(parentGame())
          || isAdmin()
        );

        allow create, update: if isSignedIn()
          && notBanned()
          && request.auth.uid == playerId
          && isMember(parentGame())
          && parentGame().phase == 'active'
          && sectorNotTerminated(parentGame());
      }

      // ── Subspace Messaging ──────────────────────────────────────────────
      // Messages are public to the sector (readable by any member). During a
      // live **rated** sector, only quick-phrase hails are allowed (no free
      // text, no DMs). Casual and unrated sectors allow free-form + DMs.
      match /messages/{messageId} {
        function parentGameForMsg() {
          return get(/databases/$(database)/documents/games/$(gameId)).data;
        }

        // Module Zeta: sender's squadronId on the parent game doc, or null.
        // Rules have no list.filter/lambda — walk the captains list (fleet ≤18).
        function senderSquadronId() {
          let captains = parentGameForMsg().captains;
          return captains.size() > 0 && captains[0].id == request.auth.uid
              ? captains[0].get('squadronId', null)
            : captains.size() > 1 && captains[1].id == request.auth.uid
              ? captains[1].get('squadronId', null)
            : captains.size() > 2 && captains[2].id == request.auth.uid
              ? captains[2].get('squadronId', null)
            : captains.size() > 3 && captains[3].id == request.auth.uid
              ? captains[3].get('squadronId', null)
            : captains.size() > 4 && captains[4].id == request.auth.uid
              ? captains[4].get('squadronId', null)
            : captains.size() > 5 && captains[5].id == request.auth.uid
              ? captains[5].get('squadronId', null)
            : captains.size() > 6 && captains[6].id == request.auth.uid
              ? captains[6].get('squadronId', null)
            : captains.size() > 7 && captains[7].id == request.auth.uid
              ? captains[7].get('squadronId', null)
            : captains.size() > 8 && captains[8].id == request.auth.uid
              ? captains[8].get('squadronId', null)
            : captains.size() > 9 && captains[9].id == request.auth.uid
              ? captains[9].get('squadronId', null)
            : captains.size() > 10 && captains[10].id == request.auth.uid
              ? captains[10].get('squadronId', null)
            : captains.size() > 11 && captains[11].id == request.auth.uid
              ? captains[11].get('squadronId', null)
            : captains.size() > 12 && captains[12].id == request.auth.uid
              ? captains[12].get('squadronId', null)
            : captains.size() > 13 && captains[13].id == request.auth.uid
              ? captains[13].get('squadronId', null)
            : captains.size() > 14 && captains[14].id == request.auth.uid
              ? captains[14].get('squadronId', null)
            : captains.size() > 15 && captains[15].id == request.auth.uid
              ? captains[15].get('squadronId', null)
            : captains.size() > 16 && captains[16].id == request.auth.uid
              ? captains[16].get('squadronId', null)
            : captains.size() > 17 && captains[17].id == request.auth.uid
              ? captains[17].get('squadronId', null)
            : null;
        }

        // Members: all messages (DMs honor-model); squad gated. Shadow-mute is
        // enforced by moving audience off 'table' + client filter — do NOT gate
        // list reads on shadowHidden (Firestore rejects queries that cannot prove
        // every matched doc is readable).
        // Spectators: public table only (audience == 'table').
        // Admins: full thread for silent supervision.
        allow read: if isSignedIn()
          && (
            isAdmin()
            || (
              isMember(parentGameForMsg())
              && (
                resource.data.get('channel', 'table') != 'squad'
                || resource.data.squadronId == senderSquadronId()
              )
            )
            || (
              isSpectator(parentGameForMsg())
              && resource.data.get('audience', 'table') == 'table'
            )
          );

        function isSectorMuted() {
          return isSignedIn()
            && exists(/databases/$(database)/documents/games/$(gameId)/mutes/$(request.auth.uid))
            && get(/databases/$(database)/documents/games/$(gameId)/mutes/$(request.auth.uid)).data.active == true
            && get(/databases/$(database)/documents/games/$(gameId)/mutes/$(request.auth.uid)).data.get('mode', 'hard') != 'shadow'
            && (
              get(/databases/$(database)/documents/games/$(gameId)/mutes/$(request.auth.uid)).data.expiresAt == null
              || get(/databases/$(database)/documents/games/$(gameId)/mutes/$(request.auth.uid)).data.expiresAt
                   > request.time
            );
        }

        // Write rules: sender must be a member; enforce rated-sector comms
        // gate at the rule level so tampered clients cannot bypass it.
        allow create: if isSignedIn()
          && notBanned()
          && notGloballyMuted()
          && !isSectorMuted()
          && sectorNotTerminated(parentGameForMsg())
          && isMember(parentGameForMsg())
          && request.resource.data.from == request.auth.uid
          && request.resource.data.get('shadowHidden', false) == false
          && request.resource.data.at is string
          && request.resource.data.kind in ['phrase', 'text']
          && request.resource.data.audience in ['table', 'dm', 'squad']
          && (
            (
              request.resource.data.audience == 'dm'
              && request.resource.data.keys().hasAny(['to'])
            )
            || (
              request.resource.data.audience == 'squad'
              && request.resource.data.get('channel', '') == 'squad'
            )
            || (
              request.resource.data.audience == 'table'
              && !request.resource.data.keys().hasAny(['to'])
              && request.resource.data.get('channel', 'table') != 'squad'
            )
          )
          // Module Zeta: a squad-channel message is always allowed (honor
          // system — coordinate strategy, never paste raw hand contents) but
          // only for a captain actually on that squad, and only when the
          // sector is actually running Module Zeta.
          && (
            (
              request.resource.data.get('channel', 'table') == 'squad'
              && parentGameForMsg().get('modules', {}).get('squadrons', false) == true
              && request.resource.data.squadronId == senderSquadronId()
              && senderSquadronId() != null
            )
            || (
              request.resource.data.get('channel', 'table') != 'squad'
              // During live rated play: only public quick-hail phrases (no text, no DM).
              && (
                // Non-active phases (lobby, complete) — anything goes.
                parentGameForMsg().phase != 'active'
                // Active unrated — anything goes.
                || parentGameForMsg().get('rated', true) == false
                // Active rated — must be a phrase with no recipient (public only).
                || (
                  request.resource.data.kind == 'phrase'
                  && request.resource.data.get('phraseId', '') != ''
                  && !request.resource.data.keys().hasAny(['text', 'to'])
                )
              )
            )
          );

        // Messages are append-only for clients — Admin SDK may set shadowHidden.
        allow update, delete: if false;
      }

      match /hands/{playerId} {
        function parentGame() {
          return get(/databases/$(database)/documents/games/$(gameId)).data;
        }

        function roundAwaitingScore(data) {
          return data.phase == 'active'
            && data.round != null
            && data.round.phase == 'ended';
        }

        allow read: if isSignedIn() && (
          request.auth.uid == playerId
          // Sector host: full table view for AI proxying and debug export.
          || (isHost(parentGame())
            && playerId in parentGame().captainIds)
          || (isMember(parentGame()) && roundAwaitingScore(parentGame()))
        );

        allow create, update: if isSignedIn()
          && notBanned()
          && playerId in parentGame().captainIds
          && (
            // Host deals every hand when launching (hands written before phase → active).
            (isHost(parentGame()) && parentGame().phase == 'lobby')
            ||
            // In play, each captain syncs only their own private hand subdoc.
            (request.auth.uid == playerId
              && parentGame().phase == 'active'
              && !roundAwaitingScore(parentGame()))
            ||
            // Host proxies AI captain hands during active play.
            (isHost(parentGame())
              && isAiCaptainId(playerId)
              && parentGame().phase == 'active'
              && !roundAwaitingScore(parentGame()))
            ||
            // Round scoring / redeal: all hands visible briefly so END_ROUND can tally
            // points and write the next deal (before the public doc advances).
            (isMember(parentGame()) && roundAwaitingScore(parentGame()))
          );

        allow delete: if isSignedIn()
          && (request.auth.uid == playerId || isHost(parentGame()));
      }
    }

    match /playerProfiles/{uid} {
      allow read: if profileIsPublic(resource.data)
        || isOwner(uid);

      allow create, update: if isOwner(uid)
        && notBanned()
        && request.resource.data.uid == uid;

      allow delete: if isOwner(uid);
    }

    match /playerStats/{uid} {
      allow read: if true;

      allow create: if isOwner(uid) && notBanned() && clientStatsCreate();

      allow update: if isOwner(uid)
        && notBanned()
        && request.resource.data.uid == uid
        && ratedStatsFieldsUnchanged()
        && clientProfileFieldsOnly();

      allow delete: if isOwner(uid);
    }

    match /publishedLogs/{logId} {
      allow read: if logIsReadable(resource.data);

      allow create: if isSignedIn()
        && notBanned()
        && request.resource.data.authorId == request.auth.uid;

      allow update, delete: if isSignedIn()
        && notBanned()
        && resource.data.authorId == request.auth.uid;
    }
  }
}
