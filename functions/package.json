{
  "name": "@warp12/functions",
  "version": "0.1.0",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "bash ../scripts/prepare-functions-packages.sh && tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions --project \"$FIREBASE_PROJECT\"",
    "test": "vitest run --config vitest.config.mts",
    "test:emulator": "cd .. && yarn test:functions:emulator"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.58.0",
    "double-eighteen": "file:vendor/double-eighteen",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "7.3.0",
    "pdf-lib": "^1.17.1",
    "warp12-engine": "file:vendor/warp12-engine"
  },
  "devDependencies": {
    "typescript": "~5.9.2"
  }
}
