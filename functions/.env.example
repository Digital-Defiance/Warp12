# Copy to .env and set a long random passphrase before deploy.
# Do not commit .env — it is gitignored.
BOOTSTRAP_ADMIN_SECRET=replace-with-openssl-rand-base64-32
# HMAC key for match certificate JSON + PDF signatures (required for approveRatedMatch).
CERTIFICATE_SIGNING_SECRET=replace-with-openssl-rand-base64-32
# ElevenLabs (admin commentator TTS only — never put this in Vite / client env).
ELEVENLABS_API_KEY=
# Optional overrides (defaults match federation commentary voice).
# ELEVENLABS_VOICE_ID=aD6riP1btT197c6dACmy
# ELEVENLABS_MODEL_ID=eleven_v3
# Optional: fleet / AI officer pronunciation dictionary (ElevenLabs).
# Keep the dictionary id stable; bump VERSION_ID after yarn tts:pronunciation-dictionary.
# ELEVENLABS_PRONUNCIATION_DICTIONARY_ID=
# Optional: Storage bucket for TTS cache + certificates.
# Must match apps/Warp12 VITE_FIREBASE_STORAGE_BUCKET.
# (Functions .env forbids the FIREBASE_ prefix.)
# GCS_BUCKET=warp-12.firebasestorage.app

