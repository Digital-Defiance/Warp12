{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Warp Ops",
  "version": "0.1.0",
  "identifier": "org.digitaldefiance.app.warpops",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:4220",
    "beforeDevCommand": "cd ../.. && yarn serve:ops",
    "beforeBuildCommand": "cd ../.. && yarn build:ops"
  },
  "app": {
    "windows": [
      {
        "title": "Warp Ops",
        "width": 1100,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "public.app-category.utilities",
    "publisher": "Digital Defiance",
    "shortDescription": "Warp fleet administration console."
  }
}
