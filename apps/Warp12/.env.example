# Firebase — warp-12 project
# https://console.firebase.google.com/project/warp-12

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=warp-12.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=warp-12
VITE_FIREBASE_STORAGE_BUCKET=warp-12.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Local Firebase Emulator Suite (Auth + Firestore + Functions).
# Used by `yarn test:e2e:firebase` via Vite mode `e2e` (see apps/Warp12/.env.e2e).
# VITE_USE_FIREBASE_EMULATORS=true

# Native Google sign-in for the Tauri apps (iOS/Android + desktop).
# Only needed for the packaged Tauri builds — the web app uses the popup flow.
# Create OAuth 2.0 client IDs in Google Cloud (see docs/mobile-google-signin.md):
#   - iOS client → keyed to bundle id org.digitaldefiance.app.warp12
#   - Desktop client → serves desktop (loopback) AND Android (custom scheme); no SHA-1 needed
VITE_GOOGLE_IOS_CLIENT_ID=
# A single "Desktop app" OAuth client (not platform-bound) serves Android AND
# desktop (macOS/Windows/Linux). VITE_GOOGLE_DESKTOP_CLIENT_ID is preferred;
# VITE_GOOGLE_ANDROID_CLIENT_ID is accepted as a fallback for the Android leg.
VITE_GOOGLE_DESKTOP_CLIENT_ID=
VITE_GOOGLE_DESKTOP_CLIENT_SECRET=
VITE_GOOGLE_ANDROID_CLIENT_ID=
# Only if you used a "Desktop/installed" client type (it carries a secret):
# VITE_GOOGLE_IOS_CLIENT_SECRET=
# VITE_GOOGLE_ANDROID_CLIENT_SECRET=
# Optional overrides if your redirect scheme is not the reversed client id:
# VITE_GOOGLE_OAUTH_REDIRECT_SCHEME=
# VITE_GOOGLE_OAUTH_REDIRECT_SCHEME_ANDROID=
