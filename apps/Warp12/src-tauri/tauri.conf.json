{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Warp 12",
  "version": "0.10.64",
  "identifier": "com.example.warp12",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "cd ../.. && yarn serve:bridge",
    "beforeBuildCommand": "cd ../.. && yarn build:all"
  },
  "app": {
    "windows": [
      {
        "title": "Warp 12",
        "width": 1280,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "public.app-category.games",
    "publisher": "Example Org",
    "shortDescription": "Multi-trail Interstellar Dominoes across Warp factors 9/12/15/18.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": null,
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "displayLanguageSelector": false
      }
    },
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "hardenedRuntime": true
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 21,
      "versionCode": 64,
      "debugApplicationIdSuffix": ".debug"
    },
    "iOS": {
      "developmentTeam": "XXXXXXXXXX",
      "minimumSystemVersion": "14.0",
      "bundleVersion": "64",
      "infoPlist": "./Info.ios.plist"
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": []
    }
  }
}
