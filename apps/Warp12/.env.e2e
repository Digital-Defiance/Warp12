# Firebase e2e — local Emulator Suite (see yarn test:e2e:firebase)
# Values are placeholders; emulators accept any web config.

VITE_USE_FIREBASE_EMULATORS=true

VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=localhost
VITE_FIREBASE_PROJECT_ID=demo-warp12
VITE_FIREBASE_STORAGE_BUCKET=demo-warp12.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:demo000000000000
