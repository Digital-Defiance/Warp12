            "serviceId": "listlistedcharters",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/fn/listMyCharters",
          "run": {
            "serviceId": "listmycharters",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/fn/rejectRatedMatch",
          "run": {
            "serviceId": "rejectratedmatch",
            "region": "us-central1"
          }
        },
        {
          "source": "/api/fn/reportOnlineMatch",
